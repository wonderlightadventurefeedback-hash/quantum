rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FinIntel AI Security Rules - V2 Optimized
     * Core Philosophy: Path-based ownership for all user data.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // Subcollections are inherently protected by the parent rule, 
      // but we define them explicitly for granular control if needed.
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // Public content
    match /learning_modules/{moduleId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();

      match /{allSubcollections=**} {
        allow get, list: if true;
        allow create, update, delete: if isAdmin();
      }
    }

    match /stocks/{stockId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /news_articles/{articleId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /admin_roles/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create, update, delete: if isAdmin();
    }
  }
}