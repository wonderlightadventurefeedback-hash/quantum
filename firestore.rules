rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FinIntel AI Security Rules
     * 
     * Core Philosophy: 
     * Path-based ownership for all user data.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);

      // Lesson progress tracking
      match /lesson_progress/{lessonId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }

      // Module-wide progress
      match /module_progress/{moduleId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }

      // Stock predictions
      match /stock_predictions/{predictionId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }

      // Flat holdings structure (Used by the current frontend)
      match /holdings/{holdingId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }

      // Portfolios and nested data
      match /portfolios/{portfolioId} {
        allow get, list, create, update, delete: if isOwner(userId);

        match /holdings/{hId} {
          allow get, list, create, update, delete: if isOwner(userId);
        }

        match /analyses/{analysisId} {
          allow get, list, create, update, delete: if isOwner(userId);
        }
      }

      // AI Chat conversations
      match /chat_conversations/{conversationId} {
        allow get, list, create, update, delete: if isOwner(userId);

        match /messages/{messageId} {
          allow get, list, create, update, delete: if isOwner(userId);
        }
      }
    }

    // Public content
    match /learning_modules/{moduleId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();

      match /lessons/{lessonId} {
        allow get, list: if true;
        allow create, update, delete: if isAdmin();

        match /quizzes/{quizId} {
          allow get, list: if true;
          allow create, update, delete: if isAdmin();

          match /questions/{questionId} {
            allow get, list: if true;
            allow create, update, delete: if isAdmin();
          }
        }
      }
    }

    match /stocks/{stockId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /news_articles/{articleId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /admin_roles/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create, update, delete: if isAdmin();
    }
  }
}