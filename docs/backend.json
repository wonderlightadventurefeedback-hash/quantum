
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the FinIntel AI platform, storing profile information and linking to all user-specific data.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "email": {
          "type": "string",
          "description": "The user's email address, used for communication and as a unique login identifier.",
          "format": "email"
        },
        "displayName": {
          "type": "string",
          "description": "The user's full display name."
        },
        "experienceLevel": {
          "type": "string",
          "enum": ["BEGINNER", "NOVICE", "INTERMEDIATE", "PRO", "UNSET"],
          "description": "The user's assessed stock market experience level."
        },
        "onboardingCompleted": {
          "type": "boolean",
          "description": "Whether the user has finished the initial experience assessment."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the user account was created.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp of the last update to the user's profile information.",
          "format": "date-time"
        },
        "lastLoginAt": {
          "type": "string",
          "description": "Timestamp of the user's last successful login.",
          "format": "date-time"
        },
        "balance": {
          "type": "number",
          "description": "The user's current demo capital balance."
        },
        "lastNewsId": {
          "type": "number",
          "description": "The ID of the last news item the user was notified about."
        }
      },
      "required": [
        "id",
        "email",
        "createdAt",
        "updatedAt"
      ]
    },
    "Notification": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Notification",
      "type": "object",
      "description": "An alert or message sent to the user regarding market news or activity.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "read": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" },
        "link": { "type": "string" },
        "sentiment": { "type": "string" }
      },
      "required": ["id", "userId", "title", "message", "type", "read", "timestamp"]
    },
    "LearningModule": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "LearningModule",
      "type": "object",
      "description": "Represents a structured section or category of financial learning content.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["id", "title", "description", "order"]
    },
    "UserLessonProgress": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserLessonProgress",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "moduleId": { "type": "string" },
        "lessonId": { "type": "string" },
        "status": { "type": "string" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "lessonId", "status"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "google",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Stores user profile and experience metadata."
        }
      }
    ]
  }
}
