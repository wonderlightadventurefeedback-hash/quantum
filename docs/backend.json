
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account information and preferences.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "balance": { "type": "number", "description": "User's current portfolio balance." },
        "learningProgress": { "type": "integer", "min": 0, "max": 100 },
        "predictionAccuracy": { "type": "integer", "min": 0, "max": 100 }
      },
      "required": ["email"]
    },
    "WatchlistItem": {
      "title": "Watchlist Item",
      "description": "A stock symbol added to a user's watchlist.",
      "type": "object",
      "properties": {
        "symbol": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["symbol", "addedAt"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/entities/UserProfile",
      "description": "Public and private user profile data."
    },
    "/users/{userId}/watchlist/{symbol}": {
      "schema": "#/entities/WatchlistItem",
      "description": "Collection of stocks watched by the user."
    }
  }
}
